# Copy this file to .env.local and fill in values before running any commands.
# Never commit .env.local — it is in .gitignore.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Required for all Prisma commands and at runtime.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/vendor_piqc?schema=public"

# ── Database (test) ──────────────────────────────────────────────────────────
# Separate Postgres database used by `npm test`. Tests truncate all tables
# between runs — never point this at a database with real data.
# Setup is documented in docs/dev-team-notes.md ("Test database setup").
# DATABASE_URL_TEST is read by `.env.test` + `vitest.config.ts`; if you keep
# .env.test out of git (recommended), set it in your shell or CI environment.
DATABASE_URL_TEST="postgresql://postgres:password@localhost:5432/vendor_piqc_test?schema=public"

# ── File storage ──────────────────────────────────────────────────────────────
# Storage provider for EvidenceAttachment uploads.
# Phase 1: S3-compatible storage. storageKey on EvidenceAttachment is the object key.
# See docs/dev-team-notes.md for setup requirements.
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""

# ── Auth (placeholder — not configured in Phase 1) ───────────────────────────
# Proper auth (NextAuth, Clerk, etc.) is a Phase 2 item.
# User rows are created manually for Phase 1. actor_id on StateHistoryDelta
# references the users table — a valid user must exist before writing deltas.
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
